generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("FACEBOOK_DATABASE_URL")
}

// ─── Pre-existing tables (never drop) ────────────────────────────────────────

model days_off {
  id            Int     @id @default(autoincrement())
  email         String?
  vacation_days Int?    @db.SmallInt
  sick_days     Int?    @db.SmallInt
}

model inventory {
  id           Int     @id @default(autoincrement())
  product_name String?
  size         String?
  in_stock     Int?
}

model n8n_vectors {
  id        String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  text      String?
  metadata  Json?
  embedding Unsupported("vector")?
}

// ─── Facebook Service ─────────────────────────────────────────────────────────

model FbMessage {
  id          String          @id @default(uuid())
  messageId   String          @unique
  recipient   String
  body        String
  mediaUrl    String?
  status      FbMessageStatus @default(PENDING)
  fbMessageId String?
  errorReason String?
  sentAt      DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([recipient])
  @@index([status])
  @@index([createdAt])
}

enum FbMessageStatus {
  PENDING
  SENT
  FAILED
  DELIVERED
}

